{
  "name": "site-hierarchy-archetypes",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --port 4173",
    "build:subtrees": "tsx scripts/build-customer-subtrees.ts",
    "build:aggregate": "tsx scripts/build-aggregate-patterns.ts",
